# OpenAI
# Keep the real key only in .env or the shell environment.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Recall backend
RECALL_HOST=127.0.0.1
RECALL_PORT=8765
RECALL_DATABASE_PATH=./data/recall.db
RECALL_LOG_LEVEL=INFO

# Comma-separated origins. Add the unpacked Chrome extension origin after its
# development ID is known. Do not use * in the submitted build.
RECALL_CORS_ORIGINS=
